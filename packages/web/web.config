<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS site-root web.config for the FULL app on https://linkshortner.microlent.com

  Layout (see folder structure):
    <site root>\            -> this web.config + the React build (index.html, assets\)
    The Node API is run separately by PM2 on http://localhost:4000
    (see packages\api\ecosystem.config.cjs).

  Routing:
    /api/*            -> proxied to Node (backend REST API)
    /assets/*, files  -> served by IIS (static React build)
    / , /analytics/*  -> React SPA (index.html)
    /<shortcode>      -> proxied to Node (302 redirect)

  Server requirements (install once):
    1. URL Rewrite module  -> https://www.iis.net/downloads/microsoft/url-rewrite
    2. ARR (Application Request Routing) -> https://www.iis.net/downloads/microsoft/application-request-routing
    3. IIS Manager -> server node -> "Application Request Routing Cache"
       -> "Server Proxy Settings..." -> tick "Enable proxy".
    4. IIS Manager -> site -> "URL Rewrite" -> right pane "View Server Variables..."
       -> add: HTTP_X_FORWARDED_HOST, HTTP_X_FORWARDED_PROTO, HTTP_X_FORWARDED_FOR
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. API -> Node backend -->
        <rule name="ApiToNode" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>

        <!-- 2. Existing static files (assets, favicon, etc.) -> let IIS serve them -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 3. React SPA routes (home + /analytics/:code) -> index.html -->
        <rule name="SpaRoutes" stopProcessing="true">
          <match url="^(analytics(/.*)?)?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>

        <!-- 4. Anything else = short code -> Node 302 redirect -->
        <rule name="ShortCodeToNode" stopProcessing="true">
          <match url="^(.+)$" />
          <action type="Rewrite" url="http://localhost:4000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <httpErrors existingResponse="PassThrough" />

    <staticContent>
      <!-- Ensure correct MIME for modern assets -->
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>
  </system.webServer>
</configuration>
