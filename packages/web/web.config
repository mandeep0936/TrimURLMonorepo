<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS site-root web.config for the FULL app on https://linkshortner.microlent.com

  Layout:
    <site root>\            -> this web.config + React build (index.html, assets\)
    Node API run by PM2 on http://localhost:4001 (see packages\api\ecosystem.config.cjs)

  Routing:
    /api/*            -> proxied to Node (backend REST API)
    /assets/*, files  -> served by IIS (static React build)
    / , /analytics/*  -> React SPA (index.html)
    /<shortcode>      -> proxied to Node (302 redirect)

  Server requirements (install once):
    1. URL Rewrite module  -> https://www.iis.net/downloads/microsoft/url-rewrite
    2. ARR (Application Request Routing) -> https://www.iis.net/downloads/microsoft/application-request-routing
    3. IIS Manager -> server node -> "Application Request Routing Cache"
       -> "Server Proxy Settings..." -> tick "Enable proxy".

  NOTE: X-Forwarded-* server variables were removed to avoid the common
  "server variable not in allowed list" 500. If you want accurate client IPs
  for rate-limiting, add them later via URL Rewrite -> "View Server Variables".
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. API -> Node backend -->
        <rule name="ApiToNode" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:4001/api/{R:1}" />
        </rule>

        <!-- 2. Existing static files -> let IIS serve them -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 3. React SPA routes (home, /analytics/:code, /not-found) -> index.html -->
        <rule name="SpaRoutes" stopProcessing="true">
          <match url="^(analytics(/.*)?|not-found)?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>

        <!-- 4. Anything else = short code -> Node 302 redirect -->
        <rule name="ShortCodeToNode" stopProcessing="true">
          <match url="^(.+)$" />
          <action type="Rewrite" url="http://localhost:4001/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
