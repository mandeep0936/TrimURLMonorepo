# MongoDB connection string (use a MongoDB Atlas URI in production)
MONGODB_URI=mongodb://localhost:27017/trim

# Port the server listens on (Render provides PORT automatically in production)
PORT=4000

# Public origin of this API — used to build short URLs. In production: https://trimurlmonorepo.onrender.com
BASE_URL=http://localhost:4000

# Allowed frontend origin(s) for CORS. Comma-separated list supported.
# In production: https://trim-url-monorepo-web.vercel.app
CLIENT_URL=http://localhost:5173

NODE_ENV=development
